{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Analysis": {
      "title": "Style Analysis",
      "description": "Stores the results of a fashion analysis.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "image": { "type": "string", "description": "Base64 or URL" },
        "dressName": { "type": "string" },
        "retailMatches": { "type": "array" },
        "blueprint": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "image", "dressName"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "Individual style analyses"
    }
  }
}
